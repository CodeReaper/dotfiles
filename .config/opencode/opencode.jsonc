{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
      },
    },
  },
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "brew list *": "allow",
      "cat *": "allow",
      "cd *": "allow",
      "curl *": "ask",
      "dotnet *": "ask",
      "dotnet --info": "allow",
      "dotnet build *": "allow",
      "dotnet restore *": "allow",
      "dotnet list *": "allow",
      "dotnet test *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "find *": "allow",
      "find * --exec *": "deny",
      "gh *": "deny",
      "git *": "ask",
      "git branch -a": "allow",
      "git branch --all": "allow",
      "git branch --show-current": "allow",
      "git branch --list *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git mv *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git submodule status": "allow",
      "go *": "allow",
      "go run *": "ask",
      "gofmt *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "hexdump *": "allow",
      "ls *": "allow",
      "python *": "deny",
      "python3 *": "deny",
      "ps *": "allow",
      "plutil -lint *": "allow",
      "printf *": "allow",
      "pwd *": "allow",
      "make *": "ask",
      "make test": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "npm ci": "allow",
      "npm view *": "allow",
      "npm run build*": "allow",
      "npm run test*": "allow",
      "rm *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "touch *": "allow",
      "true": "allow",
      "xcodebuild *": "allow",
      "xcrun simctl list *": "allow",
      "xxd *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "wget *": "deny",
    },
    "codesearch": "allow",
    "edit": "deny",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      " ~/.nuget/packages/**": "allow",
    },
  },
}
