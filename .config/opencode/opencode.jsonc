// cspell:disable

{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
      },
    },
  },
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "awk *": "allow",
      "base64 *": "allow",
      "basename *": "allow",
      "brew info *": "allow",
      "brew list *": "allow",
      "brew search *": "allow",
      "cat *": "allow",
      "cd *": "allow",
      "command *": "allow",
      "continue *": "allow",
      "cp *": "allow",
      "curl *": "deny",
      "date": "allow",
      "df *": "allow",
      "diff *": "allow",
      "docker *": "deny",
      "dot *": "allow",
      "dotnet --info": "allow",
      "dotnet *": "ask",
      "dotnet build *": "allow",
      "dotnet list *": "allow",
      "dotnet restore *": "allow",
      "dotnet sln *": "allow",
      "dotnet test *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env": "allow",
      "exec *": "deny",
      "file *": "allow",
      "find * --exec *": "deny",
      "find *": "allow",
      "gh *": "deny",
      "git *": "ask",
      "git branch *": "allow",
      "git check-ignore *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git ls-tree *": "allow",
      "git mv *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git submodule status": "allow",
      "go *": "allow",
      "go run *": "ask",
      "gofmt *": "allow",
      "grep *": "allow",
      "gzip *": "allow",
      "head *": "allow",
      "helm *": "allow",
      "hexdump *": "allow",
      "id *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "make *": "allow",
      "mkdir *": "allow",
      "mv *": "allow",
      "npm ci": "allow",
      "npm run build*": "allow",
      "npm run test*": "allow",
      "npm view *": "allow",
      "perl *": "deny",
      "pip *": "deny",
      "pip3 *": "deny",
      "plutil -lint *": "allow",
      "printf *": "allow",
      "ps *": "allow",
      "pwd *": "allow",
      "python *": "deny",
      "python3 *": "deny",
      "read *": "allow",
      "rg *": "allow",
      "rm *": "allow",
      "ruby *": "deny",
      "sed *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "strings *": "allow",
      "tail *": "allow",
      "tar *": "allow",
      "tee *": "allow",
      "textutil *": "allow",
      "touch *": "allow",
      "true": "allow",
      "uname *": "allow",
      "unzip *": "allow",
      "wc *": "allow",
      "wget *": "deny",
      "which *": "allow",
      "whoami": "allow",
      "xcodebuild *": "allow",
      "xcrun simctl list *": "allow",
      "xxd *": "allow",
      "yq *": "allow",
      "zip *": "allow",
    },
    "codesearch": "allow",
    "edit": "deny",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "~/.nuget/packages/**": "allow",
      "~/.agents/skills/*/**": "allow",
      "/tmp/**": "allow",
    },
  },
}
