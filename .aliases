#!/usr/bin/env bash

# shellcheck disable=all
# cspell:disable

# formatters
alias plist="/usr/libexec/PlistBuddy -c \"Print\" $@"
alias xml="xmllint --format -"
alias json="jq"

function jwt() {
	for index in 1 2; do
		echo $1 | cut -d. -f$index | read in
		echo $in==== | fold -w 4 | sed '$ d' | tr -d '\n' | base64 --decode | jq
	done
}

# git
alias g="git"

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep --color=auto'

# easy clean up of xcode
alias xcodeclean='rm -rf ~/library/Developer/Xcode/DerivedData/*'

# android
alias adb="~/Library/Android/sdk/platform-tools/adb"
function logcat() {
	PKG_NAME=$1
	shift
	adb logcat --pid=$(adb shell pidof -s $PKG_NAME) -v color $@
}

# network
alias netstat='netstat -anptcp'

# code
alias code='/Applications/Visual\ Studio\ Code.app/Contents/Resources/app/bin/code'

# generators
alias uuid="uuidgen | tr '[:upper:]' '[:lower:]'"

# tooling

alias serve="python -m http.server $@"

# docker tooling

alias dive='
docker run --rm -it \
-v /var/run/docker.sock:/var/run/docker.sock \
ghcr.io/wagoodman/dive $@'

alias grype='
mkdir -p /tmp/grype && \
docker run --rm \
-v /var/run/docker.sock:/var/run/docker.sock \
-v /tmp/grype:/tmp \
-e GRYPE_DB_CACHE_DIR=/tmp/grype \
anchore/grype $@'

alias trivy='
mkdir -p /tmp/trivy && \
docker run --rm \
-v /var/run/docker.sock:/var/run/docker.sock \
-v /tmp/trivy:/root/.cache/ \
aquasec/trivy image $@'

alias syft='docker run --rm ghcr.io/anchore/syft $@'

alias dfimage='
docker run --rm \
-v /var/run/docker.sock:/var/run/docker.sock \
ghcr.io/laniksj/dfimage $@'

alias ralph='sh ~/.agents/skills/ralph/scripts/loop.sh $@'
