{
  "[csharp]": {
    "editor.formatOnType": true,
    "editor.maxTokenizationLineLength": 2500
  },
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.quickSuggestions": {
      "comments": false,
      "other": true,
      "strings": true
    },
    "editor.tabSize": 2
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint" // prettier cannot use specified markdown rules
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "ansible.validation.enabled": false,
  "ansible.validation.lint.enabled": false,
  "chat.agent.enabled": false, // essential AI disabling
  "chat.disableAIFeatures": true, // essential AI disabling
  "cSpell.ignorePaths": [
    "package-lock.json",
    "node_modules",
    ".git/**",
    ".gitignore"
  ],
  "dotnet.formatting.organizeImportsOnFormat": true,
  "editor.cursorSurroundingLines": 1000, // keeps cursor centered always
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false, // minimap that is otherwise a giant scroll bar
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "rainbow1",
        "settings": {
          "foreground": "#e15e7f"
        }
      },
      {
        "scope": "keyword.rainbow2",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#3CB44B"
        }
      },
      {
        "scope": "entity.name.function.rainbow3",
        "settings": {
          "fontStyle": "italic",
          "foreground": "#FFE119"
        }
      },
      {
        "scope": "comment.rainbow4",
        "settings": {
          "fontStyle": "underline",
          "foreground": "#0082C8"
        }
      },
      {
        "scope": "string.rainbow5",
        "settings": {
          "foreground": "#FABEBE"
        }
      },
      {
        "scope": "variable.parameter.rainbow6",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#46F0F0"
        }
      },
      {
        "scope": "constant.numeric.rainbow7",
        "settings": {
          "fontStyle": "italic",
          "foreground": "#9c4597"
        }
      },
      {
        "scope": "entity.name.type.rainbow8",
        "settings": {
          "fontStyle": "underline",
          "foreground": "#008080"
        }
      },
      {
        "scope": "markup.bold.rainbow9",
        "settings": {
          "foreground": "#F58231"
        }
      },
      {
        "scope": "invalid.rainbow10",
        "settings": {
          "foreground": "#FFFFFF"
        }
      }
    ]
  },
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "afterDelay",
  "files.exclude": {
    "**/.git": true // hides .git in file explorer and searches
  },
  "files.hotExit": "onExitAndWindowClose",
  "git.openRepositoryInParentFolders": "never",
  "gitlens.ai.enabled": false,
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.codeLens.scopes": ["containers", "document"],
  "go.toolsManagement.autoUpdate": true,
  "inlineChat.affordance": "off",
  "json.schemas": [
    {
      "fileMatch": ["/.config/opencode/opencode.jsonc"],
      "url": "https://opencode.ai/config.json"
    },
    {
      "fileMatch": ["/.config/opencode/tui.jsonc"],
      "url": "https://opencode.ai/tui.json"
    },
    {
      "fileMatch": ["https://models.dev/model-schema.json"],
      "url": "https://models.dev/model-schema.json"
    }
  ],
  "makefile.configureOnOpen": false,
  "markdownlint.config": {
    "MD012": {
      "maximum": 2 // maximum number of blank lines
    },
    "MD013": false, // disable line length limit
    "MD022": {
      "lines_above": 2, // amount of blank lines before a heading
      "lines_below": 1 // amount of blank lines after a heading
    }
  },
  "merge-conflict.codeLens.enabled": false,
  "merge-conflict.decorators.enabled": false,
  "npm.exclude": [
    "**/.asdf/**",
    "**/.bun/**",
    "**/.bundle/**",
    "**/.cache/**",
    "**/.colima/**",
    "**/.git/**",
    "**/.kube/**",
    "**/.local/**",
    "**/.npm/**",
    "**/.nuget/**",
    "**/.Trash/**",
    "**/Applications/**",
    "**/Desktop/**",
    "**/Documents/**",
    "**/Downloads/**",
    "**/Library/**",
    "**/node_modules/**",
    "**/Pictures/**",
    "**/repos/**"
  ],
  "python.analysis.aiHoverSummaries": false,
  "redhat.telemetry.enabled": false,
  "scm.diffDecorationsGutterAction": "none",
  "scm.diffDecorationsGutterPattern": {
    "modified": false
  },
  "search.quickOpen.includeHistory": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.suggest.enabled": false,
  "update.showReleaseNotes": false,
  "window.zoomLevel": 1,
  "workbench.browser.openLocalhostLinks": false,
  "workbench.colorCustomizations": {
    "[Default Dark Modern]": {
      "editor.lineHighlightBackground": "#282515"
    },
    "[Tokyo Night]": {
      "editor.lineHighlightBackground": "#282515",
      "editorGutter.addedBackground": "#4c73c1",
      "editorGutter.addedSecondaryBackground": "#4c73c1",
      "editorGutter.deletedBackground": "#823c41",
      "editorGutter.deletedSecondaryBackground": "#823c41",
      "editorGutter.modifiedBackground": "#4c73c1",
      "editorGutter.modifiedSecondaryBackground": "#4c73c1"
    }
  },
  "workbench.colorTheme": "Tokyo Night",
  "workbench.settings.showAISearchToggle": false,
  "workbench.sideBar.location": "right", // avoid moving the left text edge
  "workbench.startupEditor": "none"
}
